{
  "variables": {
    "m5": { "range": [0, 3], "type": "continuous" }
  },

  "rules": [
    {
      "name": "band0_m1_off_m2_off",
      "condition": "(m1 == 0) and (m2 == 0) and (laser < 4)",
      "formula": "laser * 0.75"
    },
    {
      "name": "band1_m1_on_m2_off",
      "condition": "(m1 == 1) and (m2 == 0) and (laser >= 4) and (laser < 8)",
      "formula": "(laser - 4) * 0.75"
    },
    {
      "name": "band2_m1_off_m3_on",
      "condition": "(m1 == 0) and (m3 == 1) and (laser >= 8) and (laser < 12)",
      "formula": "(laser - 8) * 0.75"
    },
    {
      "name": "band3_m1_on_m3_on",
      "condition": "(m1 == 1) and (m3 == 1) and (laser >= 12) and (laser < 16)",
      "formula": "(laser - 12) * 0.75"
    },
    {
      "name": "band4_m2_off_m4_off",
      "condition": "(m2 == 0) and (m4 == 0) and (laser >= 16)",
      "formula": "(laser - 16) * 0.75"
    },
    {
      "name": "band_mid_m2_on_m4_on",
      "condition": "(m2 == 1) and (m4 == 1) and (laser >= 5) and (laser < 10)",
      "formula": "(laser - 5) * 0.60"
    }
  ]
}