{
  "variables": {
    "m5": { "range": [0, 3] }
  },

  "rules": [
    {
      "name": "low_sum_high_m5",
      "condition": "(m1+m2+m3+m4 <= 1) and (laser > 10)",
      "assign": { "m5": 3 }
    },
    {
      "name": "low_sum_mid_m5",
      "condition": "(m1+m2+m3+m4 <= 1) and (laser <= 10)",
      "assign": { "m5": 2 }
    },

    {
      "name": "mid_sum_high_laser",
      "condition": "(m1+m2+m3+m4 == 2) and (laser > 12)",
      "assign": { "m5": 2 }
    },
    {
      "name": "mid_sum_low_laser",
      "condition": "(m1+m2+m3+m4 == 2) and (laser < 8)",
      "assign": { "m5": 1 }
    },

    {
      "name": "high_sum_low_m5",
      "condition": "(m1+m2+m3+m4 >= 3) and (laser > 10)",
      "assign": { "m5": 1 }
    },
    {
      "name": "high_sum_very_low_m5",
      "condition": "(m1+m2+m3+m4 >= 3) and (laser <= 10)",
      "assign": { "m5": 0 }
    },

    {
      "name": "laser_extreme_low",
      "condition": "laser < 3",
      "assign": { "m5": 3 }
    }
  ]
}